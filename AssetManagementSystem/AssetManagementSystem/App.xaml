<Application x:Class="AssetManagementSystem.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="LoginPage.xaml">

    <Application.Resources>

      
        <SolidColorBrush x:Key="PrimaryBackgroundBrush" Color="#FFECEFF1"/>
        <SolidColorBrush x:Key="PrimaryAccentBrush" Color="#FF37474F"/>
        <SolidColorBrush x:Key="SecondaryAccentBrush" Color="#FF00897B"/>
        <SolidColorBrush x:Key="LightTextBrush" Color="White"/>

     
        <Style x:Key="HeaderTextStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryAccentBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>

        
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SecondaryAccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Application.Resources>

</Application>